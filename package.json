{
  "name": "monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "test": "npm run test --workspaces --if-present",
    "build:package": "npm run build:package --workspaces --if-present",
    "docs": "npm run start -w site",
    "docs:fast": "npm run start:fast -w site",
    "docs:fast:ja": "npm run start:fast -w site -- --locale ja",
    "docs:ja": "npm run start -w site -- --locale ja",
    "docs:wtr": "npm run write-translations -w site",
    "docs:wtr:ja": "npm run write-translations -w site -- --locale ja",
    "build:docs": "npm run build -w site",
    "build:docs:production": "npm run build:package && COMMIT_SHA=$(git rev-parse main) npm run build -w site",
    "clean": "npm run clean --workspaces --if-present",
    "clean:build": "npm run clean:build --workspaces --if-present"
  },
  "author": {
    "name": "mimoz",
    "email": "contact.m1m0zzz@gmail.com",
    "url": "https://m1m0zzz.github.io/"
  },
  "license": "UNLICENSED",
  "workspaces": [
    "packages/functions",
    "packages/react",
    "site"
  ],
  "devDependencies": {
    "@arethetypeswrong/core": "0.18.2",
    "@eslint/js": "9.39.4",
    "@tsdown/css": "0.21.7",
    "@types/eslint__js": "8.42.3",
    "@types/jest": "29.5.14",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-lit-a11y": "4.1.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-storybook": "10.3.4",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "publint": "0.3.18",
    "rimraf": "6.1.3",
    "ts-jest": "29.4.9",
    "tsdown": "0.21.7",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0"
  },
  "engines": {
    "node": ">=22"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
